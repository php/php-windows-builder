+
+if (!function_exists('buildphp_worker_recovery_format_test_index')) {
+    function buildphp_worker_recovery_has_object_junit()
+    {
+        return isset($GLOBALS['junit'])
+            && is_object($GLOBALS['junit'])
+            && method_exists($GLOBALS['junit'], 'mergeResults')
+            && method_exists($GLOBALS['junit'], 'clear');
+    }
+
+    function buildphp_worker_recovery_format_test_index($name, $redir_tested)
+    {
+        if (is_array($name)) {
+            return "# $name[1]: $name[0]";
+        }
+
+        if ($redir_tested) {
+            return "# $redir_tested: $name";
+        }
+
+        return $name;
+    }
+
+    function buildphp_worker_recovery_get_result_test_name($name, $redir_tested)
+    {
+        if (is_array($name) && $redir_tested) {
+            return $name[0];
+        }
+
+        return $name;
+    }
+
+    function buildphp_worker_recovery_test_file($name)
+    {
+        return is_array($name) ? $name[0] : $name;
+    }
+
+    function buildphp_worker_recovery_find_test_index(array $tests, $name)
+    {
+        $serialized = serialize($name);
+
+        foreach ($tests as $index => $candidate) {
+            if (serialize($candidate) === $serialized) {
+                return $index;
+            }
+        }
+
+        return null;
+    }
+
+    function buildphp_worker_recovery_collect_junit()
+    {
+        if (buildphp_worker_recovery_has_object_junit()) {
+            $junit = $GLOBALS['junit'];
+            return $junit->isEnabled() ? $junit : null;
+        }
+
+        if (function_exists('junit_enabled')) {
+            return junit_enabled() ? $GLOBALS['JUNIT'] : null;
+        }
+
+        return null;
+    }
+
+    function buildphp_worker_recovery_reset_junit()
+    {
+        if (buildphp_worker_recovery_has_object_junit()) {
+            $GLOBALS['junit']->clear();
+            return;
+        }
+
+        if (function_exists('junit_init')) {
+            junit_init();
+        }
+    }
+
+    function buildphp_worker_recovery_merge_junit($workerJunit)
+    {
+        if (buildphp_worker_recovery_has_object_junit()) {
+            $GLOBALS['junit']->mergeResults($workerJunit);
+            return;
+        }
+
+        if ($workerJunit !== null && function_exists('junit_enabled') && junit_enabled()) {
+            junit_merge_results($workerJunit);
+        }
+    }
+
+    function buildphp_worker_recovery_mark_bork_junit($shortname, $message)
+    {
+        if (buildphp_worker_recovery_has_object_junit()) {
+            $junit = $GLOBALS['junit'];
+            if ($junit->isEnabled()) {
+                $junit->markTestAs('BORK', $shortname, $shortname, null, $message);
+            }
+            return;
+        }
+
+        if (function_exists('junit_enabled') && junit_enabled()) {
+            junit_mark_test_as('BORK', $shortname, $shortname, null, $message);
+        }
+    }
+
+    function buildphp_worker_recovery_track_started(&$workerBatches, $workerID, $assignedName, $name, $index)
+    {
+        if (!isset($workerBatches[$workerID])) {
+            return;
+        }
+
+        $pendingIndex = buildphp_worker_recovery_find_test_index($workerBatches[$workerID]['pending'], $assignedName);
+        if ($pendingIndex !== null) {
+            unset($workerBatches[$workerID]['pending'][$pendingIndex]);
+            $workerBatches[$workerID]['pending'] = array_values($workerBatches[$workerID]['pending']);
+        }
+
+        $workerBatches[$workerID]['current'] = [
+            'name' => $name,
+            'index' => $index,
+        ];
+    }
+
+    function buildphp_worker_recovery_release_conflicts($workerID, &$activeConflicts, &$waitingTests, &$test_files)
+    {
+        foreach ($activeConflicts as $key => $activeWorkerID) {
+            if ($activeWorkerID === $workerID) {
+                unset($activeConflicts[$key]);
+                if (isset($waitingTests[$key])) {
+                    while ($test = array_pop($waitingTests[$key])) {
+                        $test_files[] = $test;
+                    }
+                    unset($waitingTests[$key]);
+                }
+            }
+        }
+    }
+
+    function buildphp_worker_recovery_mark_bork($name, $index, $message, &$PHP_FAILED_TESTS, &$test_results, $result_tests_file)
+    {
+        $file = buildphp_worker_recovery_test_file($name);
+        $shortname = str_replace(TEST_PHP_SRCDIR . '/', '', $file);
+
+        show_result('BORK', $message, $shortname);
+        $PHP_FAILED_TESTS['BORKED'][] = [
+            'name' => $file,
+            'test_name' => '',
+            'output' => '',
+            'diff' => '',
+            'info' => "$message [$file]",
+        ];
+
+        buildphp_worker_recovery_mark_bork_junit($shortname, $message);
+
+        if (!is_array($name)) {
+            $test_results[$index] = 'BORKED';
+            if ($result_tests_file) {
+                fwrite($result_tests_file, "BORKED\t$index\n");
+            }
+        }
+    }
+
+    function buildphp_worker_recovery_start_worker($workerID, &$workerProcs, &$workerSocks, $listenSock, $thisPHP, $thisScript, $workerEnv, $sockUri)
+    {
+        $proc = proc_open(
+            $thisPHP . ' ' . escapeshellarg($thisScript),
+            [],
+            $pipes,
+            null,
+            $workerEnv + [
+                "TEST_PHP_WORKER" => $workerID,
+                "TEST_PHP_URI" => $sockUri,
+            ],
+            [
+                "suppress_errors" => true,
+                'create_new_console' => true,
+            ]
+        );
+        if ($proc === false) {
+            return false;
+        }
+
+        $workerSock = stream_socket_accept($listenSock, 5);
+        if ($workerSock === false) {
+            proc_terminate($proc);
+            return false;
+        }
+
+        $greeting = base64_encode(serialize([
+            "type" => "hello",
+            "GLOBALS" => $GLOBALS,
+            "constants" => [
+                "INIT_DIR" => INIT_DIR,
+                "TEST_PHP_SRCDIR" => TEST_PHP_SRCDIR,
+                "PHP_QA_EMAIL" => PHP_QA_EMAIL,
+                "QA_SUBMISSION_PAGE" => QA_SUBMISSION_PAGE,
+                "QA_REPORTS_PAGE" => QA_REPORTS_PAGE,
+                "TRAVIS_CI" => TRAVIS_CI
+            ]
+        ])) . "\n";
+
+        stream_set_timeout($workerSock, 5);
+        if (fwrite($workerSock, $greeting) === false) {
+            fclose($workerSock);
+            proc_terminate($proc);
+            return false;
+        }
+
+        $rawReply = fgets($workerSock);
+        if ($rawReply === false) {
+            fclose($workerSock);
+            proc_terminate($proc);
+            return false;
+        }
+
+        $reply = unserialize(base64_decode($rawReply));
+        if (!$reply || $reply["type"] !== "hello_reply" || $reply["workerID"] !== $workerID) {
+            fclose($workerSock);
+            proc_terminate($proc);
+            return false;
+        }
+
+        stream_set_timeout($workerSock, 0);
+        stream_set_blocking($workerSock, false);
+
+        $workerProcs[$workerID] = $proc;
+        $workerSocks[$workerID] = $workerSock;
+
+        return true;
+    }
+
+    function buildphp_worker_recovery_handle_worker_death($workerID, &$workerProcs, &$workerSocks, &$workerBatches, &$rawMessageBuffers, &$activeConflicts, &$waitingTests, &$test_files, &$testsInProgress, &$PHP_FAILED_TESTS, &$test_results, $result_tests_file, $listenSock, $thisPHP, $thisScript, $workerEnv, $sockUri)
+    {
+        $hadBatch = isset($workerBatches[$workerID]);
+        if ($hadBatch) {
+            $testsInProgress--;
+            buildphp_worker_recovery_release_conflicts($workerID, $activeConflicts, $waitingTests, $test_files);
+
+            $currentTest = $workerBatches[$workerID]['current'];
+            if ($currentTest !== null) {
+                buildphp_worker_recovery_mark_bork(
+                    $currentTest['name'],
+                    $currentTest['index'],
+                    "Worker $workerID died unexpectedly",
+                    $PHP_FAILED_TESTS,
+                    $test_results,
+                    $result_tests_file
+                );
             }
+
+            foreach ($workerBatches[$workerID]['pending'] as $pendingTest) {
+                $test_files[] = $pendingTest;
+            }
+        }
+
+        if (isset($workerProcs[$workerID])) {
+            proc_terminate($workerProcs[$workerID]);
+            unset($workerProcs[$workerID]);
+        }
+
+        if (isset($workerSocks[$workerID])) {
+            fclose($workerSocks[$workerID]);
+            unset($workerSocks[$workerID]);
         }
+
+        unset($workerBatches[$workerID], $rawMessageBuffers[$workerID]);
+
+        if ($hadBatch && !buildphp_worker_recovery_start_worker($workerID, $workerProcs, $workerSocks, $listenSock, $thisPHP, $thisScript, $workerEnv, $sockUri)) {
+            echo "WARNING: Failed to respawn worker $workerID after an unexpected exit.\n";
+        }
     }
 }
 
